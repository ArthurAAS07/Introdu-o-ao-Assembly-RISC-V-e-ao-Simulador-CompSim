addi x11, x0, 1
sb x11, 1029(x0)

loop:
    lb x10, 1026(x0)
    andi x10, x10, 0x1
    beq x10, x0, off

on:
	slli x11, x11, 1
    sb x11, 1029(x0)

wait:
    lb x10, 1026(x0)
    andi x10, x10, 0x1
    bne x10, x0, wait

    addi x12, x0, 32
    beq x11, x12, end

    jal x0, loop

off:
    jal x0, loop

end:
    halt
